<Window x:Class="zd3_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zd3_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Название:"/>
            <TextBox x:Name="NameBox"/>
            <TextBlock Text="Стоимость 1 минуты:" Margin="0,6,0,0"/>
            <TextBox x:Name="PriceBox"/>
            <TextBlock Text="Площадь покрытия:" Margin="0,6,0,0"/>
            <TextBox x:Name="CoverageBox"/>
            <TextBlock Text="Кол-во абонентов:" Margin="0,6,0,0"/>
            <TextBox x:Name="SubsBox"/>
            <TextBlock Text="Год основания:" Margin="0,6,0,0"/>
            <TextBox x:Name="YearBox"/>
            <CheckBox x:Name="IsPlusBox" Content="Это оператор+ (потомок)"
                      Margin="0,8,0,0" Checked="IsPlusBox_Changed"
                      Unchecked="IsPlusBox_Changed"/>
            <StackPanel x:Name="PlusPanel" IsEnabled="False">
                <CheckBox x:Name="FeeBox" Content="Плата за соединение (P)" Margin="0,6,0,0"/>
                <TextBlock Text="Размер платы:" Margin="0,6,0,0"/>
                <TextBox x:Name="FeeAmountBox"/>
                <CheckBox x:Name="UnlimBox" Content="Безлимитный интернет" Margin="0,6,0,0"/>
            </StackPanel>
            <Button Content="Добавить" Click="AddButton_Click" Margin="0,10,0,0"/>
            <Button Content="Удалить выбранный" Click="RemoveButton_Click" Margin="0,6,0,0"/>
            <Button Content="Лучший оператор" Click="BestButton_Click" Margin="0,6,0,0"/>
            <Button Content="Среднее качество" Click="AvgButton_Click" Margin="0,6,0,0"/>
            <Button Content="Сортировать по качеству" Click="SortButton_Click" Margin="0,6,0,0"/>
        </StackPanel>
        <ListBox Grid.Column="1" x:Name="OperatorsList"/>
    </Grid>
</Window>
